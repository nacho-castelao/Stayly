# Copy this file to `.env` and fill in real values.
# `.env` is gitignored; never commit real secrets.

# Public base URL of the app (include trailing slash). Used for every
# redirect/link and to derive the OAuth callback and the JS base path.
APP_URL=http://localhost/Stayly/

# Database connection (defaults to the local XAMPP setup when unset).
DB_HOST=localhost
DB_NAME=stayly
DB_USER=root
DB_PASS=

# Google OAuth credentials (from the Google Cloud console).
# The redirect URI registered there must match APP_URL + "public/User/googleCallback".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
